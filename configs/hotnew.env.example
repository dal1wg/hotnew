# Standard environment config for hotnew
# Copy to your runtime environment and adjust values as needed.

# HTTP
HOTNEW_HTTP_ADDR=:8080

# Summary
HOTNEW_SUMMARY_MAX_CHARS=180

# Storage
HOTNEW_STORE_BACKEND=sqlite
HOTNEW_DATA_DIR=data
HOTNEW_SQLITE_DSN=data/hotnew.db
HOTNEW_FILE_ARTICLES_PATH=data/articles.jsonl
HOTNEW_FILE_DELIVERIES_PATH=data/deliveries.jsonl
HOTNEW_FILE_RETRIES_PATH=data/retry_jobs.jsonl
HOTNEW_FILE_RETRIES_ARCHIVE_PATH=data/retry_jobs.archive.jsonl

# Scheduler
HOTNEW_SCHEDULER_ENABLED=false
HOTNEW_SCHEDULER_INTERVAL=15m
HOTNEW_SCHEDULER_RUN_LIMIT=10
HOTNEW_SCHEDULER_RUN_TIMEOUT=30s
HOTNEW_SCHEDULER_START_IMMEDIATELY=false

# Retry
HOTNEW_RETRY_ENABLED=true
HOTNEW_RETRY_INTERVAL=1m
HOTNEW_RETRY_BATCH_SIZE=10
HOTNEW_RETRY_TIMEOUT=30s
HOTNEW_RETRY_MAX_ATTEMPTS=3
HOTNEW_RETRY_BACKOFF=5m
HOTNEW_RETRY_MAX_BACKOFF=6h
HOTNEW_RETRY_ARCHIVE_AFTER=168h
HOTNEW_RETRY_ARCHIVE_BATCH=100

# Distribution
HOTNEW_DISTRIBUTE_BUFFER=128

# Blog distribution (optional)
HOTNEW_BLOG_ENABLED=false
HOTNEW_BLOG_ENDPOINT=
HOTNEW_BLOG_TIMEOUT=5s
HOTNEW_BLOG_AUTH_TOKEN=
HOTNEW_BLOG_SITE_NAME=hotnew
HOTNEW_BLOG_AUTHOR=hotnew
HOTNEW_BLOG_MODE=markdown

# WeCom robot distribution
HOTNEW_WECOM_ENABLED=true
HOTNEW_WECOM_WEBHOOK=https://work.weixin.qq.com/wework_admin/common/openBotProfile/241d4adcd6c5849bb0de9d5b710f9e3f57
HOTNEW_WECOM_TIMEOUT=5s
